.reveal-card {
  margin-bottom: 30rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 226, 237, 0.72), transparent 28%),
    linear-gradient(180deg, rgba(255, 250, 252, 0.98), rgba(248, 238, 244, 0.96));
}

.reading-title {
  display: block;
  font-size: 56rpx;
  line-height: 1.05;
  color: #6f5764;
  margin: 20rpx 0;
}

.reading-meta {
  display: block;
  margin-bottom: 18rpx;
}

.reading-summary {
  display: block;
  line-height: 1.8;
}

.headline-pills {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
  margin-top: 24rpx;
}

.transit-card {
  margin-top: 26rpx;
}

.transit-title {
  display: block;
  margin: 12rpx 0;
  font-size: 34rpx;
}

.metrics-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-bottom: 24rpx;
}

.metric-card {
  text-align: center;
}

.metric-score {
  display: block;
  font-size: 52rpx;
  color: #ba79a7;
  margin-bottom: 10rpx;
}

.chart-card {
  margin-bottom: 24rpx;
}

.chart-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 24rpx;
}

.chart-cell {
  min-height: 150rpx;
  border-radius: 22rpx;
  background: rgba(255, 248, 251, 0.96);
  padding: 18rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(228, 202, 170, 0.24);
  min-width: 0;
}

.chart-cell-title,
.chart-cell-stars,
.chart-cell-score {
  display: block;
}

.chart-cell-title {
  color: #705865;
  font-size: 24rpx;
}

.chart-cell-stars {
  color: #998791;
  font-size: 18rpx;
  margin-top: 10rpx;
  line-height: 1.5;
}

.chart-cell-score {
  margin-top: 16rpx;
  color: #c79f58;
  font-size: 28rpx;
}

.palace-card {
  margin-bottom: 20rpx;
}

.palace-title {
  display: block;
  font-size: 34rpx;
  margin: 14rpx 0 10rpx;
}

.palace-stars {
  display: block;
  margin-bottom: 16rpx;
}

.highlights-card {
  margin-top: 20rpx;
}

.highlight-item {
  margin-top: 22rpx;
}

.highlight-title {
  display: block;
  margin-bottom: 10rpx;
  color: #c79f58;
  font-size: 26rpx;
}

.ritual-box {
  margin-top: 24rpx;
}

.ritual-reading-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 22rpx;
  margin-top: 22rpx;
}

.ritual-heading,
.ritual-line {
  display: block;
}

.ritual-heading {
  color: #c79f58;
  margin-bottom: 12rpx;
}

.ritual-heading--bad {
  color: #ffb4ab;
}

.ritual-line {
  color: #8f7d88;
  line-height: 1.8;
  font-size: 24rpx;
}

.action-row {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 30rpx;
  min-width: 0;
}

.action-primary {
  color: #4a1960;
}
