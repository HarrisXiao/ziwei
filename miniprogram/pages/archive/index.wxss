.profile-card {
  margin-bottom: 28rpx;
}

.profile-status-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.profile-hero {
  display: flex;
  gap: 22rpx;
  align-items: flex-start;
  min-width: 0;
}

.profile-cover {
  width: 138rpx;
  height: 138rpx;
  border-radius: 28rpx;
  background:
    linear-gradient(135deg, rgba(255, 235, 222, 0.96), rgba(236, 214, 199, 0.92)),
    radial-gradient(circle at center, rgba(255,255,255,0.4), rgba(237,220,206,0.2) 35%, rgba(226,204,189,0.7) 70%);
  box-shadow: 0 10rpx 30rpx rgba(205, 178, 159, 0.24);
  flex-shrink: 0;
}

.profile-copy {
  flex: 1;
  min-width: 0;
}

.profile-quote {
  display: block;
  margin-top: 10rpx;
  line-height: 1.7;
}

.profile-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
  margin-top: 20rpx;
}

.meta-label {
  display: block;
  margin-bottom: 8rpx;
  font-size: 22rpx;
}

.meta-value {
  display: block;
  color: #b78468;
  font-size: 30rpx;
}

.metrics-archive {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-bottom: 24rpx;
}

.archive-stat {
  text-align: center;
}

.archive-stat-value {
  display: block;
  color: #b78468;
  font-size: 34rpx;
  margin-bottom: 10rpx;
  line-height: 1.1;
}

.archive-actions {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-bottom: 28rpx;
}

.record-list {
  margin-top: 28rpx;
}

.archive-stat .muted {
  font-size: 20rpx;
  line-height: 1.5;
}

.service-hub-card {
  margin-bottom: 24rpx;
}

.service-hub-head {
  margin-bottom: 22rpx;
}

.service-hub-title {
  display: block;
  margin-top: 8rpx;
  margin-bottom: 12rpx;
}

.service-hub-copy {
  display: block;
  line-height: 1.7;
}

.service-hub-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.service-hub-item {
  min-height: 178rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  background: linear-gradient(180deg, rgba(255, 250, 246, 0.98), rgba(245, 236, 229, 0.96));
  border: 1rpx solid rgba(216, 187, 159, 0.28);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.service-hub-item--highlight {
  background:
    radial-gradient(circle at top right, rgba(255, 227, 198, 0.46), transparent 36%),
    linear-gradient(180deg, rgba(255, 249, 244, 0.98), rgba(246, 235, 226, 0.98));
  border-color: rgba(216, 187, 159, 0.42);
}

.service-hub-item--daily {
  background:
    radial-gradient(circle at top right, rgba(255, 227, 198, 0.46), transparent 36%),
    linear-gradient(180deg, rgba(255, 249, 244, 0.98), rgba(246, 235, 226, 0.98));
  border-color: rgba(216, 187, 159, 0.42);
}

.service-hub-item--annual {
  background:
    radial-gradient(circle at top right, rgba(206, 225, 245, 0.42), transparent 36%),
    linear-gradient(180deg, rgba(249, 252, 255, 0.98), rgba(240, 246, 252, 0.96));
  border-color: rgba(176, 205, 233, 0.4);
}

.service-hub-item--relationship {
  background:
    radial-gradient(circle at top right, rgba(246, 209, 223, 0.42), transparent 36%),
    linear-gradient(180deg, rgba(255, 250, 252, 0.98), rgba(248, 238, 244, 0.96));
  border-color: rgba(220, 181, 201, 0.4);
}

.service-hub-item--natal {
  background:
    radial-gradient(circle at top right, rgba(241, 214, 232, 0.4), transparent 36%),
    linear-gradient(180deg, rgba(255, 250, 253, 0.98), rgba(247, 239, 245, 0.96));
  border-color: rgba(213, 171, 192, 0.36);
}

.service-hub-item__label {
  display: block;
  font-size: 32rpx;
  color: #705a50;
  font-family: "Times New Roman", serif;
  line-height: 1.15;
}

.service-hub-item__desc {
  display: block;
  font-size: 22rpx;
  line-height: 1.7;
}

.archive-guide-card {
  margin-bottom: 30rpx;
}

.archive-guide-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 18rpx;
}

.archive-guide-item {
  display: flex;
  gap: 18rpx;
  align-items: flex-start;
  padding: 20rpx 0;
  border-top: 1rpx solid rgba(216, 187, 159, 0.24);
}

.archive-guide-item:first-child {
  border-top: 0;
  padding-top: 0;
}

.archive-guide-item__index {
  width: 54rpx;
  height: 54rpx;
  border-radius: 50%;
  background: rgba(244, 227, 213, 0.96);
  color: #b78468;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  letter-spacing: 1rpx;
  flex-shrink: 0;
}

.archive-guide-item__copy {
  flex: 1;
  min-width: 0;
}

.archive-guide-item__title {
  display: block;
  font-size: 28rpx;
  color: #6f5c53;
  margin-bottom: 10rpx;
}

.record-section-head {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  align-items: flex-end;
  margin-bottom: 18rpx;
  min-width: 0;
}

.record-section-title {
  display: block;
  margin-top: 8rpx;
}

.record-section-head .muted {
  flex: 1;
  text-align: right;
  line-height: 1.7;
  font-size: 22rpx;
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
  gap: 20rpx;
  background: linear-gradient(180deg, rgba(255, 251, 248, 0.98), rgba(246, 238, 232, 0.96));
  min-width: 0;
}

.record-main {
  flex: 1;
  min-width: 0;
}

.record-thumb {
  width: 108rpx;
  height: 108rpx;
  border-radius: 8rpx;
  background:
    linear-gradient(135deg, rgba(255,255,255,0.32), rgba(234,220,210,0.82)),
    radial-gradient(circle at center, rgba(255,255,255,0.3), rgba(233,220,210,0.24) 32%, rgba(223,205,194,0.78) 72%);
  border: 1rpx solid rgba(216, 187, 159, 0.22);
  flex-shrink: 0;
}

.record-name {
  display: block;
  font-size: 32rpx;
  margin-bottom: 12rpx;
  line-height: 1.2;
}

.record-summary {
  display: block;
  margin: 14rpx 0 16rpx;
  line-height: 1.7;
  font-size: 22rpx;
  max-height: 76rpx;
  overflow: hidden;
}

.record-arrow {
  font-size: 48rpx;
  color: #c19a83;
  margin-left: 4rpx;
  flex-shrink: 0;
}

.record-tags {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

@media (max-width: 720rpx) {
  .service-hub-grid {
    grid-template-columns: 1fr;
  }

  .record-section-head {
    flex-direction: column;
    align-items: flex-start;
  }

  .record-section-head .muted {
    text-align: left;
  }
}
