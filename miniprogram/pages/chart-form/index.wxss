.intro-card {
  margin-bottom: 28rpx;
  text-align: left;
}

.onboarding-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 20rpx;
}

.onboarding-item {
  display: flex;
  gap: 18rpx;
  align-items: flex-start;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(214, 187, 142, 0.22);
}

.onboarding-item:first-child {
  border-top: 0;
  padding-top: 0;
}

.onboarding-item__index {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(242, 217, 233, 0.96);
  color: #bf9960;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  flex-shrink: 0;
}

.onboarding-item__copy {
  flex: 1;
  min-width: 0;
}

.onboarding-item__title {
  display: block;
  margin-bottom: 10rpx;
  font-size: 28rpx;
  color: #6e5663;
}

.form-section {
  margin-bottom: 28rpx;
}

.preview-card {
  margin: 34rpx 0;
}

.preview-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 24rpx;
}

.preview-cell {
  min-height: 120rpx;
  border-radius: 22rpx;
  background: rgba(255, 248, 251, 0.96);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8f7d88;
  font-size: 24rpx;
  text-align: center;
  border: 1rpx solid rgba(228, 202, 170, 0.24);
  padding: 0 10rpx;
  line-height: 1.35;
  min-width: 0;
}

.preview-cell--main {
  background: rgba(243, 220, 234, 0.96);
  color: #a66693;
}

.error-box {
  margin-bottom: 28rpx;
}

.field-inline {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 12rpx;
}

.calendar-switch {
  display: flex;
  gap: 10rpx;
  padding: 8rpx;
  background: rgba(251, 242, 247, 0.96);
  border-radius: 999rpx;
  border: 1rpx solid rgba(222, 196, 209, 0.42);
  max-width: 100%;
}

.calendar-chip {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  color: #9f8392;
  font-size: 20rpx;
}

.calendar-chip--active {
  background: rgba(243, 220, 234, 0.98);
  color: #a66693;
}

.gender-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.gender-card {
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 22rpx;
  background: rgba(255, 248, 251, 0.96);
  color: #9b8893;
  border: 1rpx solid rgba(222, 196, 209, 0.42);
}

.gender-card--active {
  background: linear-gradient(135deg, rgba(255, 226, 239, 0.98), rgba(239, 198, 223, 0.96));
  color: #a66693;
}

.hour-wheel {
  position: relative;
  min-height: 150rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, rgba(255, 250, 252, 0.98), rgba(247, 239, 244, 0.96));
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(228, 202, 170, 0.24);
}

.hour-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0;
  width: 100%;
  padding: 0 22rpx;
  min-width: 0;
}

.hour-item {
  color: rgba(159, 131, 146, 0.4);
  font-size: 28rpx;
  transition: all 0.2s ease;
  width: 92rpx;
  text-align: center;
  flex-shrink: 1;
  white-space: nowrap;
}

.hour-item--1 {
  color: rgba(159, 131, 146, 0.72);
  font-size: 34rpx;
}

.hour-item--0,
.hour-item--active {
  color: #c59b53;
  font-size: 48rpx;
  font-family: "Georgia", "Times New Roman", serif;
}

.hour-fade {
  position: absolute;
  left: 0;
  right: 0;
  height: 28rpx;
  z-index: 1;
}

.hour-fade--top {
  top: 0;
  background: linear-gradient(180deg, rgba(255, 250, 252, 0.98), rgba(255, 250, 252, 0));
}

.hour-fade--bottom {
  bottom: 0;
  background: linear-gradient(0deg, rgba(247, 239, 244, 0.98), rgba(247, 239, 244, 0));
}

.hour-caption {
  display: block;
  text-align: center;
  margin-top: 12rpx;
  color: rgba(159, 131, 146, 0.74);
  font-size: 18rpx;
}
