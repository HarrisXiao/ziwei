@import "../chart-form/index.wxss";

.service-note {
  margin: 28rpx 0;
}

.service-note__title {
  display: block;
  margin: 14rpx 0 12rpx;
  color: #6e5663;
  font-size: 30rpx;
  font-family: "Georgia", "Times New Roman", serif;
}

.relationship-note {
  border-color: rgba(213, 171, 192, 0.3);
}

.relationship-focus-card {
  margin-top: 28rpx;
  background:
    radial-gradient(circle at top right, rgba(248, 210, 224, 0.42), transparent 24%),
    linear-gradient(180deg, rgba(255, 250, 252, 0.98), rgba(250, 240, 245, 0.96));
}

.relationship-flow-card {
  margin-top: 28rpx;
  background:
    radial-gradient(circle at top right, rgba(244, 205, 221, 0.34), transparent 24%),
    linear-gradient(180deg, rgba(255, 250, 252, 0.98), rgba(250, 240, 245, 0.96));
}

.relationship-flow-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 20rpx;
}

.relationship-flow-item {
  display: flex;
  gap: 18rpx;
  align-items: flex-start;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(214, 187, 142, 0.22);
}

.relationship-flow-item:first-child {
  border-top: 0;
  padding-top: 0;
}

.relationship-flow-item__index {
  width: 54rpx;
  height: 54rpx;
  border-radius: 50%;
  background: rgba(246, 219, 230, 0.96);
  color: #bd6f96;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  flex-shrink: 0;
}

.relationship-flow-item__copy {
  flex: 1;
  min-width: 0;
}

.relationship-flow-item__title {
  display: block;
  margin-bottom: 10rpx;
  font-size: 28rpx;
  color: #6e5663;
}

.relationship-form-card {
  margin-top: 28rpx;
  background:
    radial-gradient(circle at top right, rgba(247, 216, 228, 0.34), transparent 24%),
    linear-gradient(180deg, rgba(255, 251, 253, 0.98), rgba(250, 240, 245, 0.96));
}

.relationship-shortcut-card {
  margin-top: 28rpx;
  background:
    radial-gradient(circle at top right, rgba(244, 205, 221, 0.32), transparent 24%),
    linear-gradient(180deg, rgba(255, 250, 252, 0.98), rgba(250, 240, 245, 0.96));
}

.relationship-action-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 22rpx;
}

.preview-cell--relationship {
  background: rgba(255, 247, 251, 0.98);
  border-color: rgba(220, 181, 201, 0.34);
}

.preview-cell--relationship-main {
  background: rgba(246, 219, 230, 0.98);
  color: #b16c92;
}
